    {
      "id": "dNNxkFOrbZfb69q2xxJKe",
      "type": "text",
      "x": 546,
      "y": 735.880859375,
      "width": 788.1995239257812,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "gmOSzMaogPuZuW4uJ76yo",
      "index": "aT",
      "roundness": null,
      "seed": 297979728,
      "version": 154,
      "versionNonce": 2039697563,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774194198717,
      "link": null,
      "locked": false,
      "text": "Issue: One expense type can have 1 or more rules and can lead to code duplicacy\nAlso can lead to OCP\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Issue: One expense type can have 1 or more rules and can lead to code duplicacy\nAlso can lead to OCP\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pVZLBtk7CvUNwsJ8oq3t5",
      "type": "text",
      "x": 499.8125,
      "y": 830.876953125,
      "width": 940.41943359375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "gmOSzMaogPuZuW4uJ76yo",
      "index": "aU",
      "roundness": null,
      "seed": 869284176,
      "version": 120,
      "versionNonce": 410770069,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774194198717,
      "link": null,
      "locked": false,
      "text": "Rule can be applied on multiple expenses hence we should not tightly couple a rule to an expense\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Rule can be applied on multiple expenses hence we should not tightly couple a rule to an expense\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
