    {
      "id": "-7RX8TuBoNa6SHEMRCnmB",
      "type": "text",
      "x": 338.3995921716436,
      "y": 6153.630209773037,
      "width": 972.1195068359375,
      "height": 175.41371001906285,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "gmOSzMaogPuZuW4uJ76yo",
      "index": "b54",
      "roundness": null,
      "seed": 324429835,
      "version": 416,
      "versionNonce": 577529109,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "I6EYYpezuTakIocpYWPX0",
          "type": "arrow"
        },
        {
          "id": "fsaBAHIT9IqGXDZQi6dqU",
          "type": "arrow"
        }
      ],
      "updated": 1774194198717,
      "link": null,
      "locked": false,
      "text": "How to Store the mapping of the expense type and what rule will be applied on the expense type ? \nIn Prod app, this will be coming from one of these places:'\n   1.Store this config as JSON or YAML in db\n   2. Config Service (Uber Flior, works as config, kill switch service etc)\n\n                                    \n                                     Serealization and Deserialization (Jackson,Gson)",
      "fontSize": 20.047281145035754,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to Store the mapping of the expense type and what rule will be applied on the expense type ? \nIn Prod app, this will be coming from one of these places:'\n   1.Store this config as JSON or YAML in db\n   2. Config Service (Uber Flior, works as config, kill switch service etc)\n\n                                    \n                                     Serealization and Deserialization (Jackson,Gson)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dx3iMbpomsp9vJ2S-2BzV",
      "type": "text",
      "x": 538.8458574082074,
      "y": 6100.006339427048,
      "width": 1026.4993896484375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "gmOSzMaogPuZuW4uJ76yo",
      "index": "b55",
      "roundness": null,
      "seed": 370440933,
      "version": 123,
      "versionNonce": 1422385851,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774194198717,
      "link": null,
      "locked": false,
      "text": "Will be a separate server running and some other service will call that function and fetch the config data",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Will be a separate server running and some other service will call that function and fetch the config data",
